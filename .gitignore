# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Environments (Virtual Environments)
.env
.venv
venv/
ENV/
env.bak/
venv.bak/

# IDE / Editor files
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Jupyter Notebook checkpoints
.ipynb_checkpoints

# Project specific ignores
# Ignore trained model weights (very large zip files)
trained_models/*
!trained_models/.gitkeep

# Ignore logs
logs/*
!logs/.gitkeep

# Ignore running/validation result files (generated automatically by runs)
results/*
!results/.gitkeep

# LaTeX temporary build files (keep presentation.tex, presentation.pdf, and assets)
*.aux
*.fdb_latexmk
*.fls
*.log
*.nav
*.out
*.snm
*.toc
*.synctex.gz
*.blg
*.bbl
